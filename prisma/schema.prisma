generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventStatus {
  upcoming
  completed
  cancelled
}

enum WorkspaceRole {
  owner
  editor
}

model User {
  id          String                @id @default(cuid())
  name        String
  email       String                @unique
  password_hash String?
  role        String                @default("manager")
  created_at  DateTime              @default(now())
  updated_at  DateTime              @updatedAt
  memberships WorkspaceMembership[]
  sessions    Session[]
  verification_tokens EmailVerificationToken[]
  sent_workspace_invites WorkspaceInvitationToken[] @relation("WorkspaceInvitationSender")
}

model Workspace {
  id               String                   @id @default(cuid())
  name             String
  timezone         String                   @default("UTC")
  currency         String                   @default("USD")
  created_at       DateTime                 @default(now())
  updated_at       DateTime                 @updatedAt
  venues           Venue[]
  events           Event[]
  memberships      WorkspaceMembership[]
  sessions         Session[]
  daily_aggregates WorkspaceDailyAggregate[]
  invitation_tokens WorkspaceInvitationToken[]
}

model Venue {
  id           String     @id @default(cuid())
  name         String
  location     String?
  workspace_id String?
  capacity     Int
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  events       Event[]
  workspace    Workspace? @relation(fields: [workspace_id], references: [id], onDelete: SetNull)

  @@index([workspace_id])
}

model Event {
  id                 String          @id @default(cuid())
  name               String
  description        String?
  date               DateTime
  start_time         DateTime
  end_time           DateTime
  workspace_id       String?
  venue_id           String?
  capacity           Int
  expected_attendees Int             @default(0)
  ticket_price       Decimal         @db.Decimal(10, 2)
  tickets_sold       Int             @default(0)
  attendance_count   Int             @default(0)
  revenue            Decimal         @default(0) @db.Decimal(12, 2)
  status             EventStatus     @default(upcoming)
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  workspace          Workspace?      @relation(fields: [workspace_id], references: [id], onDelete: SetNull)
  venue              Venue?          @relation(fields: [venue_id], references: [id], onDelete: SetNull)
  ticket_sales       TicketSale[]
  attendance_logs    AttendanceLog[]

  @@index([workspace_id])
  @@index([workspace_id, date])
  @@index([workspace_id, status, date])
  @@index([workspace_id, created_at])
  @@index([date])
  @@index([status])
}

model WorkspaceDailyAggregate {
  id                 String    @id @default(cuid())
  workspace_id       String
  date               DateTime
  event_count        Int       @default(0)
  expected_attendees Int       @default(0)
  tickets_sold       Int       @default(0)
  attendance_count   Int       @default(0)
  revenue            Decimal   @default(0) @db.Decimal(12, 2)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  workspace          Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, date])
  @@index([workspace_id, date])
}

model WorkspaceMembership {
  id           String        @id @default(cuid())
  workspace_id String
  user_id      String
  role         WorkspaceRole @default(editor)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  workspace    Workspace     @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, user_id])
  @@index([user_id])
  @@index([workspace_id, role])
}

model Session {
  id           String    @id @default(cuid())
  user_id      String
  workspace_id String
  expires_at   DateTime
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([workspace_id])
  @@index([expires_at])
}

model TicketSale {
  id          String   @id @default(cuid())
  event_id    String
  quantity    Int
  total_price Decimal  @db.Decimal(12, 2)
  created_at  DateTime @default(now())
  event       Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@index([event_id, created_at])
}

model AttendanceLog {
  id           String   @id @default(cuid())
  event_id     String
  checkin_time DateTime
  event        Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@index([event_id, checkin_time])
}

model EmailVerificationToken {
  id             String    @id @default(cuid())
  user_id        String?
  email          String
  workspace_name String
  password_hash  String?
  token_hash     String    @unique
  expires_at     DateTime
  consumed_at    DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  user           User?     @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([email, created_at])
  @@index([expires_at])
}

model WorkspaceInvitationToken {
  id                 String        @id @default(cuid())
  workspace_id       String
  invited_by_user_id String
  invited_email      String
  invited_name       String
  invited_role       WorkspaceRole
  token_hash         String        @unique
  expires_at         DateTime
  consumed_at        DateTime?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt
  workspace          Workspace     @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  invited_by_user    User          @relation("WorkspaceInvitationSender", fields: [invited_by_user_id], references: [id], onDelete: Cascade)

  @@index([workspace_id, invited_email, created_at])
  @@index([expires_at])
}
